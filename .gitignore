.vscode/
.idea/
*.swp
*.swo
.project
.settings/

# --- Logs y Temporales ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp/
temp/
.cache/

# --- Seguridad (¡Muy importante!) ---
secrets.json
*.pem
credentials.ini
*.key
*.crt
*.p12
*.jks
*.keystore

# --- logs ---
*.log

#--- editores ---
.idea/
